#     - name: "fake_token"                  # 假 Token 蜜罐
#       type: "token"
#       content: "eyJhbGciOiJIUzI1NiJ9.honeypot"
#     - name: "fake_pii"                    # 假 PII 蜜罐
#       type: "pii"
#       content: "SSN: 000-00-0000"
#     - name: "fake_command"                # 假命令蜜罐
#       type: "command"
#       content: "sudo cat /etc/shadow"
#   watermark:
#     enabled: true                         # 启用水印追踪
#     type: "invisible_unicode"             # 水印类型: invisible_unicode | steganography
