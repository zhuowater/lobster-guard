# ===== Level 0: 快速开始（5 个必填字段） =====
# 仅填写下面 5 组字段即可启动一个最小可用实例。
listen_inbound: ":18443"          # 入站监听端口
listen_outbound: ":18444"         # 出站监听端口
management_port: 9090              # Dashboard / Management API 端口
management_token: "your-secret-token"  # 管理 API 认证
upstreams:
  - id: "default"
    address: "127.0.0.1"
    port: 19444                    # 上游 Agent / Gateway 端口

# ===== Level 1: 基础安全（推荐配置） =====
# 推荐在上线前补齐以下字段，获得基础 IM 安全能力。
channel_type: "lanxin"            # lanxin / feishu / dingtalk / wecom / generic
encryption_key: "your-aes-key"    # 消息解密密钥（如通道需要）
inbound_detect_enabled: true       # 入站检测开关
outbound_audit_enabled: true       # 出站审计开关
detect_timeout_ms: 200             # 单次检测超时

# 可选：如果你的通道使用回调验签，可一并填写
# callbackKey: "your-callback-key"
# callbackSignToken: "your-callback-sign-token"

# ===== Level 2: 高级功能（按需启用） =====
# 以下配置适合进阶场景：LLM Proxy、IFC、CaMeL、租户、API Key 等。
# 不需要就保持注释即可，不影响基础功能。

# llm_proxy:
#   enabled: true
#   listen: ":18445"
#   targets:
#     - name: "deepseek"
#       upstream: "https://api.deepseek.com"
#       path_prefix: "/v1/"
#       strip_prefix: false
#       api_key_header: "Authorization"

# ifc:
#   enabled: true
#   violation_action: warn
#   quarantine_enabled: false

# plan_compiler:
#   enabled: true
#   strict_mode: false

# capability:
#   enabled: true
#   default_policy: allow

# deviation:
#   enabled: true
#   auto_repair: false

# counterfactual:
#   enabled: false
#   mode: "async"

# api_keys:
#   - name: "demo"
#     key: "replace-me"

# 兼容说明：
# - 本示例使用更友好的向导字段名：listen_inbound / listen_outbound / management_port / upstreams / channel_type。
# - 后端校验 API 会自动兼容这些别名。
# - 真正部署时，也可以继续使用项目原生字段名（如 inbound_listen / static_upstreams / channel）。
