# ============================================================
# 龙虾卫士 v20.7 核心配置
# 完整参考: config.yaml.full-example（776 行完整版）
# 模块配置: conf.d/ 目录（可选，按需启用）
# ============================================================

# --- 通道（必填）---
# 支持: lanxin | feishu | dingtalk | wecom | generic
channel: "lanxin"
callbackKey: "YOUR_CALLBACK_KEY_BASE64"
callbackSignToken: "YOUR_CALLBACK_SIGN_TOKEN"

# --- 接入模式 ---
# mode: "webhook"          # webhook（默认）| bridge（长连接，飞书/钉钉）

# --- 代理端口 ---
inbound_listen: ":18443"   # IM 入站代理（消息平台 → Agent）
outbound_listen: ":18444"  # IM 出站代理（Agent → 消息平台 API）
openclaw_upstream: "http://localhost:18790"
lanxin_upstream: "https://apigw.lx.qianxin.com"

# --- 管理 ---
management_listen: ":9090"
management_token: "YOUR_MANAGEMENT_TOKEN"

# --- JWT 认证 ---
auth:
  enabled: true
  jwt_secret: "your-jwt-secret-at-least-32-chars"
  # token_expire_hours: 24
  # default_password: "admin"

# --- 存储 & 日志 ---
db_path: "/var/lib/lobster-guard/audit.db"
log_level: "info"
# log_format: "text"       # "text" | "json"

# --- 安全检测（核心开关）---
inbound_detect_enabled: true
outbound_audit_enabled: true

# --- 服务注册 ---
registration_enabled: true
registration_token: "YOUR_REGISTRATION_TOKEN"

# --- 路由策略 ---
route_default_policy: "least-users"
route_persist: true

# --- 静态上游 ---
static_upstreams:
  - id: "openclaw-local"
    address: "127.0.0.1"
    port: 18790

# --- 白名单（跳过入站检测的 sender_id）---
whitelist:
  - "YOUR_ADMIN_SENDER_ID"

# --- 执行信封（密码学审计链）---
envelope_enabled: true
envelope_secret_key: "your-hmac-secret-key-change-me"

# --- 模块配置目录 ---
# 默认 "conf.d"（相对于本文件），取消注释可自定义路径
# conf_dir: "conf.d"
#
# conf.d/ 目录下每个 .yaml/.yml 文件按字母序加载，合并到此配置。
# 不存在时静默跳过，单文件配置模式完全向后兼容。
# 示例文件见 conf.d/ 目录。
